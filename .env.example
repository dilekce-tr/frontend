# API base URL (Rails backend)
NUXT_PUBLIC_API_BASE=http://localhost:3012/api/v1

# Contact form endpoint on the Sylow forms API (defaults to the prod
# URL in nuxt.config.ts). Set to the local Rails-on-3013 when developing.
# NUXT_PUBLIC_FORMS_ENDPOINT=http://localhost:3013/api/v1/forms/yazbirdilekce.com/contact
